<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- WebView (invisible until page finishes loading) -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible" />

    <!-- Splash / Loading overlay (shown while page first loads) -->
    <LinearLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="32dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:letterSpacing="0.03"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:layout_marginBottom="64dp" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="@color/green_primary" />

    </LinearLayout>

    <!-- Offline / No Internet screen -->
    <LinearLayout
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_wifi_off"
            android:layout_marginBottom="28dp"
            android:contentDescription="@string/offline_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offline_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offline_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/try_again"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/btn_green_rounded" />

    </LinearLayout>

    <!-- Biometric lock screen (topmost — appears over all other views) -->
    <LinearLayout
        android:id="@+id/lockView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:letterSpacing="0.03"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:layout_marginBottom="52dp" />

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_lock"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/biometric_subtitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/biometric_hint"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="36dp" />

        <Button
            android:id="@+id/authenticateButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/authenticate"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/btn_green_rounded" />

    </LinearLayout>

</FrameLayout>
